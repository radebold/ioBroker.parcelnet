{
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": {
        "en": "General",
        "de": "Allgemein"
      },
      "items": {
        "apiKey": {
          "type": "password",
          "label": {
            "en": "Parcel API key",
            "de": "Parcel API-Key"
          },
          "help": {
            "en": "Create the key at web.parcelapp.net.",
            "de": "Den Schlüssel erzeugst du unter web.parcelapp.net."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "filterMode": {
          "type": "select",
          "label": {
            "en": "Filter mode",
            "de": "Filtermodus"
          },
          "options": [
            {
              "label": {
                "en": "Active deliveries",
                "de": "Aktive Lieferungen"
              },
              "value": "active"
            },
            {
              "label": {
                "en": "Recent deliveries",
                "de": "Letzte Lieferungen"
              },
              "value": "recent"
            }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "pollIntervalMinutes": {
          "type": "number",
          "label": {
            "en": "Polling interval (minutes)",
            "de": "Polling-Intervall (Minuten)"
          },
          "min": 3,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "requestTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Request timeout (ms)",
            "de": "Request-Timeout (ms)"
          },
          "min": 5000,
          "step": 1000,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "maxItemsInHtml": {
          "type": "number",
          "label": {
            "en": "Max items in VIS HTML",
            "de": "Max. Einträge im VIS-HTML"
          },
          "min": 1,
          "step": 1,
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "visSortBy": {
          "type": "select",
          "label": {
            "en": "VIS sorting",
            "de": "VIS-Sortierung"
          },
          "options": [
            {
              "label": {
                "en": "Expected delivery",
                "de": "Geplante Lieferung"
              },
              "value": "expected"
            },
            {
              "label": {
                "en": "Title",
                "de": "Titel"
              },
              "value": "title"
            },
            {
              "label": {
                "en": "Carrier",
                "de": "Carrier"
              },
              "value": "carrier"
            },
            {
              "label": {
                "en": "Status code",
                "de": "Statuscode"
              },
              "value": "status"
            }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "visSortDirection": {
          "type": "select",
          "label": {
            "en": "Sort direction",
            "de": "Sortierreihenfolge"
          },
          "options": [
            {
              "label": {
                "en": "Ascending",
                "de": "Aufsteigend"
              },
              "value": "asc"
            },
            {
              "label": {
                "en": "Descending",
                "de": "Absteigend"
              },
              "value": "desc"
            }
          ],
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showTrackingNumberInHtml": {
          "type": "checkbox",
          "label": {
            "en": "Show tracking number in VIS HTML",
            "de": "Trackingnummer im VIS-HTML anzeigen"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        },
        "showDemoWhenEmpty": {
          "type": "checkbox",
          "label": {
            "en": "Show demo carriers when API returns no deliveries",
            "de": "Demo-Carrier anzeigen, wenn die API keine Sendungen liefert"
          },
          "help": {
            "en": "Only affects the VIS HTML states. Real delivery states stay empty.",
            "de": "Betrifft nur die VIS-HTML-States. Echte Liefer-States bleiben leer."
          },
          "sm": 12,
          "md": 8,
          "lg": 6
        },
        "logRawResponse": {
          "type": "checkbox",
          "label": {
            "en": "Log raw API response (debug)",
            "de": "Rohantwort der API loggen (Debug)"
          },
          "sm": 12,
          "md": 4,
          "lg": 3
        }
      }
    },
    "carrierTab": {
      "type": "panel",
      "label": {
        "en": "Carrier logos",
        "de": "Carrier-Logos"
      },
      "items": {
        "logoInfo": {
          "type": "staticText",
          "text": {
            "en": "Use the selection field to upload or choose images directly from vis.0/main/img/parcelnet. The upload button is provided by the fileSelector itself.",
            "de": "Nutze die Auswahlfelder, um Bilder direkt aus vis.0/main/img/parcelnet hochzuladen oder auszuwählen. Der Upload-Button kommt direkt vom fileSelector."
          },
          "sm": 12,
          "md": 12,
          "lg": 12
        },
        "logoFolder": {
          "type": "text",
          "label": {
            "en": "Logo folder",
            "de": "Logo-Ordner"
          },
          "help": {
            "en": "Target folder for uploaded carrier logos. Recommended: /vis.0/main/img/parcelnet",
            "de": "Zielordner für hochgeladene Carrier-Logos. Empfohlen: /vis.0/main/img/parcelnet"
          },
          "sm": 12,
          "md": 8,
          "lg": 6,
          "hidden": true
        },
        "carrierLogo_parcel": {
          "type": "fileSelector",
          "label": {
            "en": "Default / fallback logo",
            "de": "Standard-/Fallback-Logo"
          },
          "sm": 12,
          "md": 6,
          "lg": 4,
          "pattern": "main/img/parcelnet/*.*",
          "help": {
            "en": "Upload or select an image from vis.0/main/img/parcelnet. Requires Admin 6 and vis.0.",
            "de": "Bild aus vis.0/main/img/parcelnet hochladen oder auswählen. Benötigt Admin 6 und vis.0."
          },
          "objectID": "vis.0",
          "fileTypes": "image",
          "upload": "main/img/parcelnet",
          "refresh": true,
          "delete": false,
          "noNone": false,
          "noSize": true,
          "withFolder": false,
          "maxSize": 2048
        },
