        "logoInfo": {
          "type": "staticText",
          "text": {
            "en": "Direct upload is disabled in this beta because it can crash in some Admin versions. Upload files with the ioBroker file manager and paste the path here, for example /adapter/parcelnet/carriers/dhl.svg or /vis.0/main/img/parcelnet/dhl.png.",
            "de": "Der direkte Upload ist in dieser Beta deaktiviert, weil er in manchen Admin-Versionen abstürzen kann. Lade Dateien über den ioBroker-Dateimanager hoch und trage den Pfad hier ein, z. B. /adapter/parcelnet/carriers/dhl.svg oder /vis.0/main/img/parcelnet/dhl.png."
          },
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12
        },
